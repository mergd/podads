{
  "name": "podads-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-16",
  "routes": [
    { "pattern": "podads.yet-to-be.com/feeds/*", "zone_name": "yet-to-be.com" },
    { "pattern": "podads.yet-to-be.com/api/*", "zone_name": "yet-to-be.com" },
    { "pattern": "podads.yet-to-be.com/audio/*", "zone_name": "yet-to-be.com" }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "podads",
      "database_id": "725b5729-8e37-45b3-a847-b503a95854f9",
      "migrations_dir": "./schema"
    }
  ],
  "r2_buckets": [
    {
      "binding": "AUDIO_BUCKET",
      "bucket_name": "podads-audio"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "PROCESSING_QUEUE",
        "queue": "podads-processing"
      }
    ]
  },
  "vars": {
    "PROCESSING_VERSION": "v1",
    "MAX_EPISODES_PER_FEED_REFRESH": "2",
    "MAX_PROCESSABLE_EPISODES_PER_FEED": "2",
    "POSTHOG_HOST": "https://us.i.posthog.com"
  },
  "triggers": {
    "crons": [
      "*/30 * * * *"
    ]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
