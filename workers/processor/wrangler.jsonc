{
  "name": "podads-processor",
  "main": "src/queue.ts",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "podads",
      "database_id": "725b5729-8e37-45b3-a847-b503a95854f9"
    }
  ],
  "r2_buckets": [
    {
      "binding": "AUDIO_BUCKET",
      "bucket_name": "podads-audio"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "PROCESSING_QUEUE",
        "queue": "podads-processing"
      }
    ],
    "consumers": [
      {
        "queue": "podads-processing",
        "max_batch_size": 1,
        "max_retries": 2,
        "retry_delay": 30
      }
    ]
  },
  "vars": {
    "APP_BASE_URL": "http://localhost:8787",
    "PROCESSING_VERSION": "v1",
    "CLASSIFICATION_PROVIDER": "openrouter",
    "OPENROUTER_CLASSIFICATION_MODEL": "google/gemini-3.1-flash-lite-preview",
    "OPENROUTER_CLASSIFICATION_FALLBACK_MODEL": "qwen/qwen3.6-plus",
    "TRANSCRIPTION_GATEWAY_URL": "https://transcriber-production-e6f9.up.railway.app",
    "POSTHOG_HOST": "https://us.i.posthog.com"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "triggers": {
    "crons": [
      "*/15 * * * *"
    ]
  }
}
