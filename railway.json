{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/transcriber/Dockerfile",
    "watchPatterns": [
      "services/transcriber/**",
      "packages/shared/**",
      "package.json",
      "bun.lock",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health"
  }
}
